{
  "name": "@taskforge/db",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "migrate": "dotenv -e ../../.env -- prisma migrate deploy --schema=prisma/schema.prisma",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev --schema=prisma/schema.prisma",
    "generate": "dotenv -e ../../.env -- prisma generate --schema=prisma/schema.prisma",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  }
}
