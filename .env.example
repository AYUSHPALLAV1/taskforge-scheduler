# ==========================================
# TaskForge — Environment Variables Template
# Copy to .env and fill in real values
# ==========================================

# --- Database (Neon) ---
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"
DATABASE_URL_POOLED="postgresql://user:pass@ep-xxx-pooler.neon.tech/neondb?sslmode=require&pgbouncer=true"

# --- Redis (Upstash) ---
REDIS_URL="rediss://default:xxx@xxx.upstash.io:6379"

# --- Google Gemini ---
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-1.5-flash"
GEMINI_RPM_LIMIT="10"
GEMINI_RPD_LIMIT="1000"

# --- JWT ---
JWT_SECRET="change-this-to-a-long-random-secret-at-least-64-characters-long"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- App ---
NODE_ENV="development"
PORT="3000"
CORS_ORIGIN="http://localhost:5173"

# --- Worker ---
WORKER_CONCURRENCY="8"
WORKER_POLL_MIN_MS="2000"
WORKER_POLL_MAX_MS="10000"
WORKER_HEARTBEAT_MS="10000"
WORKER_GRACE_PERIOD_MS="25000"

# --- Scheduler ---
SCHEDULER_TICK_MS="1000"
SCHEDULER_LEADER_LOCK_TTL_MS="10000"

# --- Frontend ---
VITE_API_URL="http://localhost:3000"
VITE_WS_URL="http://localhost:3000"
